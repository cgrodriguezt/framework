import sys
from bootstrap.app import app

if __name__ == "__main__":
    """Execute the CLI kernel with command-line arguments.

    Retrieve an instance of the CLI kernel from the application container
    and call its handle method, forwarding all command-line arguments
    received by the script.

    Returns
    -------
    None
        This script executes the CLI kernel and exits with the returned
        status code.
    """

    # Handle the command-line arguments using the CLI kernel
    status = app.handleCommand(sys.argv)

    # Exit the script with the status code returned by the command handler
    sys.exit(status)