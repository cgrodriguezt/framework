import sys
from bootstrap.app import app
from orionis.console.contracts.kernel import IKernelCLI

if __name__ == "__main__":
    """
    Execute the CLI kernel with command-line arguments.

    Retrieve an instance of the CLI kernel from the application container and call
    its `handle` method, forwarding all command-line arguments received by the script.

    Returns
    -------
    int
        The exit code produced by the kernel's `handle` method. Returns 0 on success,
        or a non-zero value on error or abnormal termination.
    """

    # Retrieve the CLI kernel instance from the application container
    kernel: IKernelCLI = app.make(IKernelCLI)

    # Forward command-line arguments to the kernel's handle method and execute
    kernel.handle(sys.argv)
